# ══════════════════════════════════════════════════════════════════════════════
# SalesPilotAI CRM — Environment Configuration
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SalesPilot AI CRM
APP_VERSION=0.1.0
# Set to false in production
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Use service name "db" inside Docker, "localhost" for local dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/salespilot

# Used by docker-compose.prod.yml to configure the postgres container
POSTGRES_DB=salespilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Redis ─────────────────────────────────────────────────────────────────────
# Use service name "redis" inside Docker, "localhost" for local dev
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=
REDIS_MAX_MEMORY=256mb

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Gunicorn (production only) ────────────────────────────────────────────────
# Recommended: (2 × CPU cores) + 1
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
LOG_LEVEL=info

# ── Nginx (production only) ───────────────────────────────────────────────────
NGINX_HTTP_PORT=80

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2
CELERY_EMAIL_SYNC_INTERVAL_SECONDS=600
CELERY_CONCURRENCY=2

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30.0

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# In production set to your real domain:
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/auth/gmail/callback
GMAIL_TOKEN_FILE=gmail_token.json

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFICATION_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ── Monitoring — Prometheus + Grafana ──────────────────────────────────────────
# Grafana UI is available at http://<host>:${GRAFANA_PORT}
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-password

# ── Sentry (error tracking) ────────────────────────────────────────────────────
# Backend DSN — leave empty to disable Sentry on the backend
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Fraction of transactions captured for performance monitoring (0.0–1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend DSN — leave empty to disable Sentry on the frontend
VITE_SENTRY_DSN=
VITE_APP_ENV=production
VITE_APP_VERSION=0.1.0

# Source-maps upload (CI/CD only — leave empty for local dev)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=salespilotai-frontend
