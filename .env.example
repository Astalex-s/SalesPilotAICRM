# Application
APP_NAME=SalesPilot AI CRM
APP_VERSION=0.1.0
DEBUG=true

# Database (use service name "db" inside docker, "localhost" outside)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/salespilot

# Redis (use service name "redis" inside docker, "localhost" outside)
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
